{
  "expo": {
    "name": "MusicScoodle Students",
    "slug": "musicscoodlestudents",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "music-lessons-students",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera so students can take photos or scan documents for their lessons.",
        "NSPhotoLibraryUsageDescription": "Allow access to choose photos to use in the app.",
        "NSPhotoLibraryAddUsageDescription": "Allow saving images generated by the app to your photo library.",
        "NSMicrophoneUsageDescription": "Allow microphone access if recording audio or video for lessons."
      },
      "bundleIdentifier": "com.musicscoodlestudents.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.musicscoodlestudents.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#64a8d1"
        }
      ],
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "owner": "dudluu",
    "extra": {
      "eas": {
        "projectId": "446335c7-e4c6-4ee1-9d0b-52efd59bcfbf"
      }
    }
  }
}
